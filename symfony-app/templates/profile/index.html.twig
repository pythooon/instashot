{% extends 'base.html.twig' %}

{% block title %}Profile - {{ profile.username }}{% endblock %}

{% block styles %}
    <style>
        .profile-container {
            max-width: 800px;
            margin: 0 auto;
            background: white;
            border-radius: 16px;
            padding: 40px;
            box-shadow: 0 10px 40px rgba(0,0,0,0.2);
        }
        
        .profile-header {
            text-align: center;
            margin-bottom: 40px;
            padding-bottom: 30px;
            border-bottom: 2px solid #f0f0f0;
        }
        
        .profile-avatar {
            width: 120px;
            height: 120px;
            background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
            border-radius: 50%;
            display: flex;
            align-items: center;
            justify-content: center;
            color: white;
            font-size: 48px;
            font-weight: bold;
            margin: 0 auto 20px;
            box-shadow: 0 8px 20px rgba(0,0,0,0.15);
        }
        
        .profile-username {
            font-size: 2em;
            color: #333;
            margin-bottom: 5px;
        }
        
        .profile-handle {
            font-size: 1.2em;
            color: #999;
        }
        
        .profile-details {
            display: grid;
            gap: 25px;
        }
        
        .profile-field {
            background: #f8f9fa;
            padding: 20px;
            border-radius: 12px;
            border-left: 4px solid #667eea;
        }
        
        .profile-field-label {
            font-size: 0.85em;
            color: #667eea;
            font-weight: 600;
            text-transform: uppercase;
            letter-spacing: 0.5px;
            margin-bottom: 8px;
        }
        
        .profile-field-value {
            font-size: 1.1em;
            color: #333;
            word-wrap: break-word;
        }
        
        .profile-field-empty {
            color: #999;
            font-style: italic;
        }
        
        .profile-bio {
            background: #f8f9fa;
            padding: 20px;
            border-radius: 12px;
            border-left: 4px solid #764ba2;
            margin-top: 10px;
        }
        
        .profile-bio-label {
            font-size: 0.85em;
            color: #764ba2;
            font-weight: 600;
            text-transform: uppercase;
            letter-spacing: 0.5px;
            margin-bottom: 8px;
        }
        
        .profile-bio-text {
            font-size: 1.1em;
            color: #555;
            line-height: 1.6;
        }
        
        .back-button {
            display: inline-block;
            margin-top: 30px;
            padding: 12px 30px;
            background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
            color: white;
            text-decoration: none;
            border-radius: 25px;
            font-weight: 600;
            transition: transform 0.2s ease, box-shadow 0.2s ease;
            box-shadow: 0 4px 12px rgba(102, 126, 234, 0.3);
        }
        
        .back-button:hover {
            transform: translateY(-2px);
            box-shadow: 0 6px 20px rgba(102, 126, 234, 0.4);
        }
        
        .profile-stats {
            display: flex;
            justify-content: center;
            gap: 40px;
            margin-top: 30px;
            padding-top: 30px;
            border-top: 2px solid #f0f0f0;
        }
        
        .stat-item {
            text-align: center;
        }
        
        .stat-number {
            font-size: 2em;
            font-weight: bold;
            color: #667eea;
            margin-bottom: 5px;
        }
        
        .stat-label {
            font-size: 0.9em;
            color: #999;
            text-transform: uppercase;
            letter-spacing: 0.5px;
        }

        .phoenix-panel {
            margin-top: 28px;
            padding: 24px;
            border-radius: 12px;
            background: #f0f4ff;
            border: 1px solid #c5d0f0;
        }

        .phoenix-panel h2 {
            font-size: 1.1em;
            color: #445;
            margin-bottom: 12px;
        }

        .phoenix-panel input[type="text"],
        .phoenix-panel input[type="password"] {
            width: 100%;
            max-width: 100%;
            padding: 12px 14px;
            border: 1px solid #ccd;
            border-radius: 8px;
            font-size: 1em;
            margin-bottom: 12px;
            box-sizing: border-box;
        }

        .remove-token-option {
            display: flex;
            align-items: center;
            gap: 8px;
            font-size: 0.88em;
            color: #555;
            margin: 10px 0 14px 0;
            cursor: pointer;
        }

        .remove-token-option input {
            margin: 0;
        }

        .phoenix-actions {
            display: flex;
            flex-wrap: wrap;
            gap: 12px;
            align-items: center;
        }

        .btn-primary {
            padding: 12px 22px;
            border: none;
            border-radius: 25px;
            background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
            color: white;
            font-weight: 600;
            cursor: pointer;
            font-size: 0.95em;
        }

        .btn-primary:hover {
            opacity: 0.95;
        }

        .btn-secondary {
            padding: 12px 22px;
            border-radius: 25px;
            border: 2px solid #667eea;
            background: white;
            color: #667eea;
            font-weight: 600;
            cursor: pointer;
            font-size: 0.95em;
        }

        .token-status {
            font-size: 0.9em;
            color: #555;
            margin-bottom: 10px;
        }
    </style>
{% endblock %}

{% block body %}
    <div class="profile-container">
        <div class="profile-header">
            <div class="profile-avatar">
                {{ profile.username|slice(0, 1)|upper }}
            </div>
            <h1 class="profile-username">
                {% if profile.name %}
                    {{ profile.name }} {{ profile.lastName|default('') }}
                {% else %}
                    {{ profile.username }}
                {% endif %}
            </h1>
            <div class="profile-handle">@{{ profile.username }}</div>
            <p style="margin-top: 14px; font-size: 0.92em; color: #666; line-height: 1.5; max-width: 520px; margin-left: auto; margin-right: auto;">
                Profil — dane konta, liczba zdjęć oraz <strong>import z Phoenix API</strong> (poniżej). Strona główna: galeria, filtry, polubienia po zalogowaniu.
            </p>
        </div>
        
        <div class="profile-details">
            <div class="profile-field">
                <div class="profile-field-label">Email</div>
                <div class="profile-field-value">{{ profile.email }}</div>
            </div>
            
            {% if profile.age %}
                <div class="profile-field">
                    <div class="profile-field-label">Age</div>
                    <div class="profile-field-value">{{ profile.age }} years old</div>
                </div>
            {% endif %}
            
            {% if profile.name %}
                <div class="profile-field">
                    <div class="profile-field-label">Full Name</div>
                    <div class="profile-field-value">
                        {{ profile.name }}
                        {% if profile.lastName %}
                            {{ profile.lastName }}
                        {% endif %}
                    </div>
                </div>
            {% endif %}
        </div>
        
        {% if profile.bio %}
            <div class="profile-bio">
                <div class="profile-bio-label">About Me</div>
                <div class="profile-bio-text">{{ profile.bio }}</div>
            </div>
        {% endif %}
        
        <div class="profile-stats">
            <div class="stat-item">
                <div class="stat-number">{{ profile.photosCount }}</div>
                <div class="stat-label">Photos</div>
            </div>
        </div>

        <div id="phoenix-import" class="phoenix-panel">
            <h2>Import zdjęć</h2>
            <div class="token-status">
                {% if profile.hasPhoenixAccessToken %}
                    Token: <strong>zapisany</strong>
                {% else %}
                    Token: <strong>brak</strong>
                {% endif %}
            </div>
            <form method="post" action="{{ path('profile_phoenix_token_save') }}">
                <input type="hidden" name="_token" value="{{ csrf_token(phoenix_token_csrf) }}">
                <label for="phoenix_access_token" class="profile-field-label">Token dostępu</label>
                <input id="phoenix_access_token" type="password" name="phoenix_access_token" autocomplete="new-password" spellcheck="false" autocapitalize="off" placeholder="">
                <label class="remove-token-option">
                    <input type="checkbox" name="remove_phoenix_token" value="1">
                    Usuń zapisany token
                </label>
                <div class="phoenix-actions">
                    <button type="submit" class="btn-primary">Zapisz token</button>
                </div>
            </form>
            <form method="post" action="{{ path('profile_import_phoenix') }}" style="margin-top: 18px;">
                <input type="hidden" name="_token" value="{{ csrf_token(phoenix_import_csrf) }}">
                <button type="submit" class="btn-secondary">Importuj zdjęcia</button>
            </form>
        </div>
        
        <div style="text-align: center;">
            <a href="{{ path('home') }}" class="back-button">← Back to Gallery</a>
        </div>
    </div>
{% endblock %}
