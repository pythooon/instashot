{
  "name": "zadanie/symfony-app",
  "type": "project",
  "require": {
    "php": "^8.5",
    "doctrine/annotations": "^2.0",
    "doctrine/doctrine-bundle": "^2.10",
    "doctrine/doctrine-migrations-bundle": "^3.6",
    "doctrine/orm": "^2.16",
    "symfony/asset": "^6.4",
    "symfony/dotenv": "^6.4",
    "symfony/form": "^6.4",
    "symfony/framework-bundle": "^6.4",
    "symfony/http-client": "^6.4",
    "symfony/monolog-bundle": "^3.9",
    "symfony/runtime": "^6.4",
    "symfony/security-bundle": "^6.4",
    "symfony/security-csrf": "^6.4",
    "symfony/serializer": "^6.4",
    "symfony/skeleton": "6.4.*",
    "symfony/twig-bundle": "^6.4",
    "symfony/validator": "^6.4",
    "symfony/yaml": "^6.4"
  },
  "require-dev": {
    "phpstan/phpstan": "^1.12",
    "phpstan/phpstan-symfony": "^1.4",
    "phpunit/phpunit": "^10.5",
    "squizlabs/php_codesniffer": "^3.10",
    "symfony/browser-kit": "6.4.*",
    "symfony/css-selector": "6.4.*",
    "symfony/maker-bundle": "^1.53",
    "symfony/phpunit-bridge": "^8.0"
  },
  "autoload": {
    "psr-4": {
      "App\\": "src/"
    },
    "classmap": [
      "src/",
      "migrations/"
    ]
  },
  "autoload-dev": {
    "psr-4": {
      "Tests\\": "tests/"
    }
  },
  "config": {
    "sort-packages": true,
    "allow-plugins": {
      "symfony/runtime": true,
      "symfony/flex": true
    }
  },
  "scripts": {
    "auto-scripts": {
      "cache:clear": "symfony-cmd",
      "assets:install %PUBLIC_DIR%": "symfony-cmd"
    },
    "post-install-cmd": [
      "@auto-scripts"
    ],
    "post-update-cmd": [
      "@auto-scripts"
    ],
    "phpstan": "phpstan analyse --memory-limit=512M",
    "phpcs": "phpcs",
    "phpcbf": "phpcbf",
    "phpcpd": "php -d error_reporting=22527 tools/phpcpd.phar --min-lines 5 --min-tokens 70 src tests",
    "test": "phpunit",
    "database:seed": "php bin/console app:seed --no-interaction",
    "database:init": [
      "php bin/console doctrine:migrations:migrate --no-interaction --allow-no-migration",
      "@database:seed"
    ],
    "quality": [
      "@phpstan",
      "@phpcs",
      "@phpcpd",
      "@test"
    ]
  },
  "extra": {
    "symfony": {
      "allow-contrib": false,
      "require": "6.4.*"
    }
  },
  "minimum-stability": "stable",
  "prefer-stable": true
}
